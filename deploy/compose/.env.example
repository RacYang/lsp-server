# 复制为 deploy/compose/.env，填入真实凭据后再 docker compose up。
# 真实 .env 不进入 Git；仓库根 .gitignore 已排除 deploy/compose/.env。

# PostgreSQL 凭据（应用与数据库容器共用）。
POSTGRES_USER=lsp
POSTGRES_PASSWORD=replace-me-strong-password
POSTGRES_DB=lsp

# 镜像 tag：默认 local 走本地 build；正式发布请改为 vX.Y.Z 或 <service>-<short_sha>。
GATE_IMAGE_TAG=local
ROOM_IMAGE_TAG=local
LOBBY_IMAGE_TAG=local

# 监听端口：仅 gate WebSocket 暴露到宿主机，其余依赖容器只在 compose 内网通信。
GATE_WS_HOST_PORT=18080

# 可观测端口：默认仅绑定到 127.0.0.1 调试用，对外发布请反向代理后再开放。
GATE_OBS_HOST_PORT=18081
ROOM_OBS_HOST_PORT=19083
LOBBY_OBS_HOST_PORT=19084
